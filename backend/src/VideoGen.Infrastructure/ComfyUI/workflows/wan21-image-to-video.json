{
  "1": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{PRODUCT_IMAGE_PATH}}" }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": { "image": "{{REFERENCE_IMAGE_PATH}}" }
  },
  "3": {
    "class_type": "WanTextEncode",
    "inputs": { "text": "{{POSITIVE_PROMPT}}", "wan_text_encoder": ["10", 0] }
  },
  "4": {
    "class_type": "WanTextEncode",
    "inputs": { "text": "{{NEGATIVE_PROMPT}}", "wan_text_encoder": ["10", 0] }
  },
  "5": {
    "class_type": "WanImageToVideo",
    "inputs": {
      "product_image": ["1", 0],
      "reference_image": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "seed": {{SEED}},
      "width": {{WIDTH}},
      "height": {{HEIGHT}},
      "frames": {{FRAMES}},
      "model": ["11", 0],
      "vae": ["12", 0]
    }
  },
  "6": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["5", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "motion-studio",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  },
  "10": { "class_type": "WanTextEncoderLoader", "inputs": {} },
  "11": { "class_type": "WanModelLoader", "inputs": {} },
  "12": { "class_type": "VAELoader", "inputs": {} }
}
